---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const SOCIALS = {
	twitter: 'https://x.com/sifxtreme',
	linkedin: 'https://www.linkedin.com/in/asifhahmed',
	github: 'https://github.com/sifxtreme',
};
---

<header>
	<nav>
		<a class="site-title" href="/">{SITE_TITLE}</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Writing</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href={SOCIALS.twitter} target="_blank" rel="me noopener">
				<span class="sr-only">X / Twitter</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
					><path
						fill="currentColor"
						d="M12.6 0h2.454l-5.36 6.778L16 16h-4.937l-3.867-5.594L2.771 16H.316l5.733-7.25L0 0h5.063l3.495 5.114L12.6 0Zm-.86 14.376h1.36L4.323 1.539H2.865l8.875 12.837Z"
					></path></svg
				>
			</a>
			<a href={SOCIALS.linkedin} target="_blank" rel="me noopener">
				<span class="sr-only">LinkedIn</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
					><path
						fill="currentColor"
						d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146Zm4.943 12.248V6.169H2.542v7.225h2.401Zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016Zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4Z"
					></path></svg
				>
			</a>
			<a href={SOCIALS.github} target="_blank" rel="me noopener">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
			<button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle light and dark theme" title="Toggle theme">
				<span class="sr-only">Toggle theme</span>
				<svg class="icon-moon" viewBox="0 0 16 16" aria-hidden="true" width="18" height="18"><path fill="currentColor" d="M6 .278a.77.77 0 0 1 .08.858 7.2 7.2 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277q.792-.001 1.533-.16a.79.79 0 0 1 .81.316.73.73 0 0 1-.031.893A8.35 8.35 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.75.75 0 0 1 6 .278"></path></svg>
				<svg class="icon-sun" viewBox="0 0 16 16" aria-hidden="true" width="18" height="18"><path fill="currentColor" d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6m0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8M8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0m0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13m8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5M3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8m10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0m-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0m9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707M4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708"></path></svg>
			</button>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(var(--surface), 0.85);
		backdrop-filter: saturate(150%) blur(8px);
		border-bottom: 1px solid rgb(var(--border));
		position: sticky;
		top: 0;
		z-index: 20;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 900px;
		margin: 0 auto;
	}
	.site-title {
		font-weight: 700;
		font-size: 1.05rem;
		letter-spacing: -0.02em;
		color: rgb(var(--black));
		text-decoration: none;
		padding: 0.9em 0.4em;
	}
	.site-title:hover {
		color: var(--accent);
	}
	nav a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.internal-links {
		display: flex;
		gap: 0.25em;
	}
	.internal-links :global(a) {
		padding: 1em 0.6em;
		border-bottom: 2px solid transparent;
		font-size: 0.95rem;
	}
	.internal-links :global(a.active) {
		border-bottom-color: var(--accent);
		color: rgb(var(--black));
	}
	.social-links {
		display: flex;
		gap: 0.3em;
	}
	.social-links a {
		display: flex;
		align-items: center;
		padding: 0.5em;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: var(--accent);
	}
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		padding: 0.5em;
		color: rgb(var(--gray));
		background: none;
		border: 0;
		cursor: pointer;
	}
	.theme-toggle:hover {
		color: var(--accent);
	}
	.theme-toggle .icon-sun {
		display: none;
	}
	:global(html[data-theme='dark']) .theme-toggle .icon-moon {
		display: none;
	}
	:global(html[data-theme='dark']) .theme-toggle .icon-sun {
		display: inline-flex;
	}
	@media (max-width: 720px) {
		.social-links a {
			display: none;
		}
		.site-title {
			font-size: 1rem;
		}
	}
</style>
<script is:inline>
	document
		.getElementById('theme-toggle')
		?.addEventListener('click', function () {
			var el = document.documentElement;
			var next = el.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
			el.setAttribute('data-theme', next);
			try {
				localStorage.setItem('theme', next);
			} catch (e) {}
		});
</script>
