---
// Share row for the bottom of a post. Plain <a> tags to each network's share
// endpoint, plus a copy-link button. No SDKs, no tracking pixels, no third-party
// script: those load code from someone else's server onto a page about keeping
// your own data. Same pill styling as CopyForLLM.
//
// Note on X: prefilling a tweet that contains a link is what a share button is
// FOR, but X suppresses reach on posts with off-platform links. That's the
// reader's tradeoff to make, not ours. When *I* post my own work, the link goes
// in a reply.
interface Props {
	title: string;
	url: string;
}

const { title, url } = Astro.props;

const x = `https://x.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
const linkedin = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
// Engineers are the audience, so HN belongs here more than Facebook does.
const hn = `https://news.ycombinator.com/submitlink?u=${encodeURIComponent(url)}&t=${encodeURIComponent(title)}`;
---

<div class="share">
	<span class="share__label">Share</span>

	<a class="share__btn" href={x} target="_blank" rel="noopener" aria-label="Share on X">
		<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
			<path
				d="M18.24 2.25h3.31l-7.23 8.26 8.5 11.24h-6.66l-5.21-6.82-5.97 6.82H1.66l7.73-8.84L1.25 2.25h6.83l4.71 6.23 5.45-6.23Zm-1.16 17.52h1.83L7.01 4.13H5.05l12.03 15.64Z"
			></path>
		</svg>
		<span>X</span>
	</a>

	<a class="share__btn" href={linkedin} target="_blank" rel="noopener" aria-label="Share on LinkedIn">
		<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
			<path
				d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.22 8.02h4.56V24H.22V8.02Zm7.55 0h4.37v2.18h.06c.61-1.15 2.1-2.36 4.32-2.36 4.62 0 5.48 3.04 5.48 7v9.16h-4.56v-8.12c0-1.94-.04-4.43-2.7-4.43-2.7 0-3.11 2.11-3.11 4.29V24H7.77V8.02Z"
			></path>
		</svg>
		<span>LinkedIn</span>
	</a>

	<a class="share__btn" href={hn} target="_blank" rel="noopener" aria-label="Submit to Hacker News">
		<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
			<path d="M0 0v24h24V0H0Zm12.9 13.4V19h-1.8v-5.6L6.6 5h2.1l3.3 6.4L15.3 5h2.1l-4.5 8.4Z"></path>
		</svg>
		<span>HN</span>
	</a>

	<button class="share__btn share__copy" type="button" data-url={url} aria-label="Copy link to this post">
		<svg
			class="share__icon--link"
			width="13"
			height="13"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
			<path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
		</svg>
		<svg
			class="share__icon--done"
			width="13"
			height="13"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2.5"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<polyline points="20 6 9 17 4 12"></polyline>
		</svg>
		<span class="share__copy-label">Copy link</span>
	</button>
</div>

<script>
	document.querySelectorAll<HTMLButtonElement>('.share__copy').forEach((btn) => {
		const label = btn.querySelector('.share__copy-label');
		const original = label?.textContent ?? 'Copy link';
		let timer: ReturnType<typeof setTimeout> | undefined;

		btn.addEventListener('click', async () => {
			const text = btn.dataset.url ?? '';
			try {
				await navigator.clipboard.writeText(text);
			} catch {
				// Fallback for insecure contexts without the async clipboard API.
				const ta = document.createElement('textarea');
				ta.value = text;
				ta.style.position = 'fixed';
				ta.style.opacity = '0';
				document.body.appendChild(ta);
				ta.select();
				document.execCommand('copy');
				ta.remove();
			}

			btn.classList.add('is-copied');
			if (label) label.textContent = 'Copied';
			clearTimeout(timer);
			timer = setTimeout(() => {
				btn.classList.remove('is-copied');
				if (label) label.textContent = original;
			}, 2000);
		});
	});
</script>

<style>
	.share {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5em;
		margin: 3rem 0 0;
		padding-top: 1.5rem;
		border-top: 1px solid rgb(var(--border));
	}

	.share__label {
		margin-right: 0.15em;
		color: rgb(var(--gray));
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
	}

	.share__btn {
		display: inline-flex;
		align-items: center;
		gap: 0.45em;
		padding: 0.3em 0.75em;
		border: 1px solid rgb(var(--border));
		border-radius: 999px;
		background: rgb(var(--surface));
		color: rgb(var(--gray-dark));
		font-family: inherit;
		font-size: 0.8rem;
		font-weight: 600;
		line-height: 1;
		letter-spacing: 0.01em;
		text-decoration: none;
		cursor: pointer;
		transition:
			color 0.15s ease,
			border-color 0.15s ease,
			background 0.15s ease;
	}

	.share__btn:hover,
	.share__btn:focus-visible {
		color: var(--accent-dark);
		border-color: rgba(var(--accent-rgb), 0.5);
		background: rgba(var(--accent-rgb), 0.08);
		outline: none;
	}

	.share__icon--done {
		display: none;
	}
	.share__copy.is-copied {
		color: var(--accent-dark);
		border-color: rgba(var(--accent-rgb), 0.5);
		background: rgba(var(--accent-rgb), 0.12);
	}
	.share__copy.is-copied .share__icon--link {
		display: none;
	}
	.share__copy.is-copied .share__icon--done {
		display: inline;
	}
</style>
