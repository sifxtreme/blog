---
// A build receipt for the post, from the Claude Code session that authored it.
// Numbers come from scripts/session-telemetry.mjs, scoped to the authoring
// window (first edit → first deploy). Telemetry over vibes.
interface Telemetry {
	model: string;
	ccVersion?: string;
	liveAfterMin: number;
	redeploys: number;
	instructions: number;
	turns: number;
	toolCalls: number;
	compacts: number;
	phoneRelayed: boolean;
}
interface Props {
	telemetry: Telemetry;
	aiUsage: string;
}
const { telemetry: t, aiUsage } = Astro.props;
const verb = aiUsage === 'ai-written' ? 'Written by' : 'Written with';
const live =
	t.liveAfterMin < 1
		? 'within a minute of starting'
		: `${t.liveAfterMin} min after I started`;
const plural = (n: number, w: string) => `${n} ${w}${n === 1 ? '' : 's'}`;
---

<aside class="telemetry" aria-label="How this post was made">
	<div class="eyebrow">// build receipt</div>
	<p>
		{verb} <b>{t.model}</b>{t.ccVersion ? ` (${t.ccVersion})` : ''} in one Claude
		Code session. First draft live <b>{live}</b>{
			t.redeploys > 0 ? (
				<span>, then <b>{t.redeploys}</b> {t.redeploys === 1 ? 'deploy' : 'deploys'} of polish</span>
			) : null
		}. I typed <b>{t.instructions}</b> {t.instructions === 1 ? 'instruction' : 'instructions'};
		it took <b>{t.turns}</b> turns and <b>{t.toolCalls}</b> tool calls.{
			t.compacts > 0 ? (
				<span> It compacted itself <b>{t.compacts}</b>×.</span>
			) : null
		}{t.phoneRelayed ? <span> Driven from my phone.</span> : null}
	</p>
</aside>

<style>
	.telemetry {
		margin-top: 3.5em;
		padding-top: 1.2em;
		border-top: 1px solid rgb(var(--border));
		color: rgb(var(--gray));
		font-size: 0.9rem;
		line-height: 1.65;
	}
	.eyebrow {
		font-family: ui-monospace, 'SF Mono', Menlo, monospace;
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin-bottom: 0.5em;
		color: rgb(var(--gray));
	}
	.telemetry p {
		margin: 0;
	}
	.telemetry b {
		font-family: ui-monospace, 'SF Mono', Menlo, monospace;
		font-weight: 600;
		font-size: 0.86em;
		color: rgb(var(--black));
	}
	@media (max-width: 720px) {
		.telemetry {
			margin-top: 2.5em;
			font-size: 0.85rem;
		}
	}
</style>
