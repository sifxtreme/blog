---
import { SITE_TITLE, CAL_URL } from '../consts';
const today = new Date();
---

<footer>
	<span class="book">
		<a href={CAL_URL} target="_blank" rel="noopener">Book 15 minutes with me</a> to talk
		tech or philosophy or leadership.
	</span>
	<span>&copy; {today.getFullYear()} {SITE_TITLE}</span>
	<span class="built"><a href="/how-these-are-written/">Every post says how AI was used.</a></span>
</footer>
<style>
	footer {
		padding: 2.5em 1em 4em;
		border-top: 1px solid rgb(var(--border));
		color: rgb(var(--gray));
		font-size: 0.85rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: 0.4em;
	}
	.book a {
		color: var(--accent);
		font-weight: 600;
	}
	.built {
		opacity: 0.75;
	}
	.built a {
		color: inherit;
		text-decoration: underline;
		text-underline-offset: 2px;
	}
</style>
