---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<span>&copy; {today.getFullYear()} {SITE_TITLE}</span>
	<span class="built">Written by a human. Built with Astro.</span>
</footer>
<style>
	footer {
		padding: 2.5em 1em 4em;
		border-top: 1px solid rgb(var(--border));
		color: rgb(var(--gray));
		font-size: 0.85rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: 0.4em;
	}
	.built {
		opacity: 0.75;
	}
</style>
