---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import asifHead from '../assets/asif-head.png';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<Image
					class="avatar"
					src={asifHead}
					alt={SITE_TITLE}
					width={112}
					height={112}
					densities={[1, 2]}
				/>
				<div>
					<h1>{SITE_TITLE}</h1>
					<!-- TODO(asif): rewrite this in your own voice. Keep it short. -->
					<p>{SITE_DESCRIPTION}</p>
				</div>
			</section>

			<section class="writing">
				<h2>Writing</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="post-title">{post.data.title}</span>
									<FormattedDate date={post.data.pubDate} />
								</a>
								<p class="post-desc">{post.data.description}</p>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>

	<style>
		.intro {
			display: flex;
			align-items: center;
			gap: 1.4em;
			padding: 1em 0 2.5em;
			border-bottom: 1px solid rgb(var(--border));
		}
		.avatar {
			width: 96px;
			height: 96px;
			border-radius: 50%;
			object-fit: cover;
			object-position: center top;
			flex-shrink: 0;
			border: 3px solid rgb(var(--surface));
			box-shadow: var(--box-shadow);
		}
		.intro h1 {
			font-size: 2.2rem;
			margin-bottom: 0.2em;
		}
		@media (max-width: 520px) {
			.intro {
				flex-direction: column;
				align-items: flex-start;
				text-align: left;
			}
		}
		.intro p {
			color: rgb(var(--gray));
			font-size: 1.15rem;
			margin: 0;
		}
		.writing {
			margin-top: 2.5em;
		}
		.writing h2 {
			font-size: 0.85rem;
			text-transform: uppercase;
			letter-spacing: 0.12em;
			color: rgb(var(--gray));
			margin-bottom: 1.5em;
			margin-top: 0;
		}
		.writing ul {
			list-style: none;
			margin: 0;
			padding: 0;
		}
		.writing li {
			padding: 1.1em 0;
			border-bottom: 1px solid rgb(var(--border));
		}
		.writing li a {
			display: flex;
			align-items: baseline;
			justify-content: space-between;
			gap: 1em;
			text-decoration: none;
		}
		.post-title {
			color: rgb(var(--black));
			font-weight: 700;
			font-size: 1.2rem;
			letter-spacing: -0.01em;
		}
		.writing li a:hover .post-title {
			color: var(--accent);
		}
		.writing li a :global(time) {
			color: rgb(var(--gray));
			font-size: 0.85rem;
			white-space: nowrap;
			flex-shrink: 0;
		}
		.post-desc {
			color: rgb(var(--gray));
			margin: 0.4em 0 0;
			font-size: 1rem;
		}
	</style>
</html>
