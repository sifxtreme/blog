---
import { getCollection } from 'astro:content';
import AIBadge from '../../components/AIBadge.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing · ${SITE_TITLE}`} description="Everything I've written." />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<h1>Writing</h1>
				<p>Notes on building software with AI, and the occasional link worth your time.</p>
			</header>

			<ul class="posts">
				{
					posts.map((post) => {
						const isLink = Boolean(post.data.link);
						const permalink = `/blog/${post.id}/`;
						return (
							<li>
								<div class="row">
									<a
										class="post-link"
										href={isLink ? post.data.link : permalink}
										{...(isLink ? { target: '_blank', rel: 'noopener' } : {})}
									>
										<span class="post-title">{post.data.title}</span>
										{isLink && (
											<span class="ext" aria-hidden="true">
												↗
											</span>
										)}
									</a>
									<a class="permalink" href={permalink}>
										<FormattedDate date={post.data.pubDate} />
									</a>
								</div>
								{post.data.description && (
									<p class="desc">{post.data.description}</p>
								)}
								<div class="tail">
									<AIBadge usage={post.data.aiUsage} />
									{post.data.tags?.length > 0 && (
										<span class="tags">
											{post.data.tags.map((t) => (
												<span class="tag">#{t}</span>
											))}
										</span>
									)}
								</div>
							</li>
						);
					})
				}
			</ul>
		</main>
		<Footer />
	</body>

	<style>
		.page-head {
			padding: 1em 0 2em;
			border-bottom: 1px solid rgb(var(--border));
			margin-bottom: 0.5em;
		}
		.page-head h1 {
			font-size: 2.4rem;
			margin-bottom: 0.25em;
		}
		.page-head p {
			color: rgb(var(--gray));
			margin: 0;
			font-size: 1.05rem;
		}
		.posts {
			list-style: none;
			margin: 0;
			padding: 0;
		}
		.posts li {
			padding: 1.6em 0;
			border-bottom: 1px solid rgb(var(--border));
		}
		.row {
			display: flex;
			align-items: baseline;
			justify-content: space-between;
			gap: 1em;
		}
		.post-link {
			text-decoration: none;
			display: inline-flex;
			align-items: baseline;
			gap: 0.3em;
			min-width: 0;
		}
		.post-title {
			color: rgb(var(--black));
			font-weight: 700;
			font-size: 1.35rem;
			letter-spacing: -0.015em;
			line-height: 1.25;
		}
		.post-link:hover .post-title {
			color: var(--accent);
		}
		.ext {
			color: var(--accent);
			font-size: 0.9rem;
			flex-shrink: 0;
		}
		.permalink {
			color: rgb(var(--gray));
			font-size: 0.85rem;
			text-decoration: none;
			white-space: nowrap;
			flex-shrink: 0;
		}
		.permalink:hover {
			color: var(--accent);
		}
		.desc {
			color: rgb(var(--gray));
			margin: 0.5em 0 0;
			font-size: 1rem;
			line-height: 1.55;
		}
		.tail {
			display: flex;
			align-items: center;
			flex-wrap: wrap;
			gap: 0.75em;
			margin-top: 0.9em;
		}
		.tags {
			display: inline-flex;
			flex-wrap: wrap;
			gap: 0.5em;
		}
		.tag {
			font-size: 0.78rem;
			color: rgb(var(--gray));
		}
		@media (max-width: 600px) {
			.row {
				flex-direction: column;
				gap: 0.2em;
			}
		}
	</style>
</html>
